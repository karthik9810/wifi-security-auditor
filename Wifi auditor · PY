# ── SIGNAL STRENGTH RATING ────────────────────────────────────
def signal_rating(signal):
    try:
        signal = int(signal)
        if signal >= -50:
            return Color.GREEN,  "Excellent 📶📶📶📶"
        elif signal >= -60:
            return Color.GREEN,  "Good      📶📶📶"
        elif signal >= -70:
            return Color.YELLOW, "Fair      📶📶"
        else:
            return Color.RED,    "Weak      📶"
    except:
        return Color.WHITE, "Unknown"

# ── SECURITY RATING ───────────────────────────────────────────
def security_rating(auth):
    auth = auth.upper()
    if 'WPA3' in auth:
        return Color.GREEN,  "🟢 VERY SECURE   (WPA3)"
    elif 'WPA2' in auth:
        return Color.GREEN,  "🟢 SECURE        (WPA2)"
    elif 'WPA' in auth:
        return Color.YELLOW, "🟡 MODERATE      (WPA)"
    elif 'WEP' in auth:
        return Color.RED,    "🔴 VULNERABLE!   (WEP - Easily cracked!)"
    elif 'OPEN' in auth or auth == '' or 'NONE' in auth:
        return Color.RED,    "🔴 OPEN NETWORK! (No Password - DANGEROUS!)"
    else:
        return Color.CYAN,   "🔵 UNKNOWN       (" + auth + ")"

# ── SCAN WiFi — WINDOWS ───────────────────────────────────────
def scan_windows():
    networks = []
    try:
        result = subprocess.run(
            ['netsh', 'wlan', 'show', 'networks', 'mode=Bssid'],
            capture_output=True, text=True, timeout=15
        )
        lines = result.stdout.split('\n')
        current = {}
        for line in lines:
            line = line.strip()
            if line.startswith('SSID') and 'BSSID' not in line:
                if current:
                    networks.append(current)
                    current = {}
                parts = line.split(':', 1)
                current['ssid'] = parts[1].strip() if len(parts) > 1 else 'Hidden'
            elif 'Authentication' in line:
                parts = line.split(':', 1)
                current['auth'] = parts[1].strip() if len(parts) > 1 else 'Unknown'
            elif 'Encryption' in line:
                parts = line.split(':', 1)
                current['encryption'] = parts[1].strip() if len(parts) > 1 else 'Unknown'
            elif 'Signal' in line:
                parts = line.split(':', 1)
                current['signal'] = parts[1].strip().replace('%','') if len(parts) > 1 else '0'
            elif 'BSSID 1' in line:
                parts = line.split(':', 1)
                current['bssid'] = parts[1].strip() if len(parts) > 1 else 'Unknown'
            elif 'Radio type' in line:
                parts = line.split(':', 1)
                current['radio'] = parts[1].strip() if len(parts) > 1 else 'Unknown'
        if current:
            networks.append(current)
    except Exception as e:
        print(f"{Color.RED}Error scanning: {e}{Color.RESET}")
    return networks

# ── SCAN WiFi — LINUX ─────────────────────────────────────────
def scan_linux():
    networks = []
    try:
        # Try nmcli first
        result = subprocess.run(
            ['nmcli', '-f', 'SSID,BSSID,MODE,CHAN,RATE,SIGNAL,BARS,SECURITY',
             'device', 'wifi', 'list'],
            capture_output=True, text=True, timeout=15
        )
        lines = result.stdout.strip().split('\n')
        if len(lines) > 1:
            for line in lines[1:]:
                parts = line.split()
                if len(parts) >= 6:
                    networks.append({
                        'ssid':   parts[0] if parts[0] != '--' else 'Hidden',
                        'signal': parts[5],
                        'auth':   ' '.join(parts[7:]) if len(parts) > 7 else 'Unknown',
                        'bssid':  parts[1] if len(parts) > 1 else 'Unknown',
                        'radio':  'Unknown'
                    })
    except FileNotFoundError:
        try:
            # Fallback to iwlist
            iface = 'wlan0'
            result = subprocess.run(
                ['sudo', 'iwlist', iface, 'scan'],
                capture_output=True, text=True, timeout=15
            )
            current = {}
            for line in result.stdout.split('\n'):
                line = line.strip()
                if 'ESSID:' in line:
                    if current: networks.append(current); current = {}
                    current['ssid'] = line.split('"')[1] if '"' in line else 'Hidden'
                elif 'Signal level' in line:
                    parts = line.split('Signal level=')
                    if len(parts) > 1:
                        current['signal'] = parts[1].split(' ')[0].replace('dBm','')
                elif 'Encryption key' in line:
                    current['auth'] = 'WPA' if 'on' in line.lower() else 'OPEN'
                elif 'Address:' in line:
                    current['bssid'] = line.split('Address:')[1].strip()
            if current: networks.append(current)
        except Exception as e:
            print(f"{Color.RED}Error: {e}{Color.RESET}")
    return networks

# ── GET CURRENT CONNECTED NETWORK ─────────────────────────────
def get_connected_network():
    system = platform.system()
    try:
        if system == 'Windows':
            result = subprocess.run(
                ['netsh', 'wlan', 'show', 'interfaces'],
                capture_output=True, text=True, timeout=10
            )
            for line in result.stdout.split('\n'):
                if 'SSID' in line and 'BSSID' not in line:
                    parts = line.split(':', 1)
                    if len(parts) > 1:
                        return parts[1].strip()
        elif system == 'Linux':
            result = subprocess.run(
                ['nmcli', '-t', '-f', 'active,ssid', 'dev', 'wifi'],
                capture_output=True, text=True, timeout=10
            )
            for line in result.stdout.split('\n'):
                if line.startswith('yes:'):
                    return line.split(':')[1]
    except:
        pass
    return None

# ── DISPLAY NETWORKS ──────────────────────────────────────────
def display_networks(networks):
    if not networks:
        print(f"{Color.RED}  No networks found or permission denied!{Color.RESET}")
        print(f"{Color.YELLOW}  💡 Try running as Administrator/sudo{Color.RESET}")
        return

    # Stats
    total     = len(networks)
    open_nets = 0
    wep_nets  = 0
    secure    = 0

    print(f"\n{Color.PURPLE}{'═'*70}{Color.RESET}")
    print(f"{Color.BOLD}{Color.CYAN}  📡 NETWORKS FOUND: {total}{Color.RESET}")
    print(f"{Color.PURPLE}{'═'*70}{Color.RESET}\n")

    for i, net in enumerate(networks, 1):
        ssid       = net.get('ssid', 'Hidden')
        auth       = net.get('auth', 'Unknown')
        signal_raw = net.get('signal', '0')
        bssid      = net.get('bssid', 'Unknown')
        radio      = net.get('radio', 'Unknown')

        # Windows signal is %, convert to dBm-like for rating
        try:
            sig_val = int(signal_raw)
            if sig_val > 0 and sig_val <= 100:
                # Windows percentage
                sig_dbm = -100 + (sig_val / 2)
                sig_color, sig_label = signal_rating(sig_dbm)
                sig_display = f"{signal_raw}%"
            else:
                sig_color, sig_label = signal_rating(signal_raw)
                sig_display = f"{signal_raw} dBm"
        except:
            sig_color, sig_label = Color.WHITE, "Unknown"
            sig_display = signal_raw

        sec_color, sec_label = security_rating(auth)

        # Count for summary
        auth_upper = auth.upper()
        if 'OPEN' in auth_upper or auth_upper in ['', 'NONE']:
            open_nets += 1
        elif 'WEP' in auth_upper:
            wep_nets += 1
        else:
            secure += 1

        print(f"  {Color.BOLD}{Color.WHITE}[{i:02d}] {Color.CYAN}{ssid}{Color.RESET}")
        print(f"       {Color.WHITE}BSSID      : {Color.YELLOW}{bssid}")
        print(f"       {Color.WHITE}Security   : {sec_color}{sec_label}{Color.RESET}")
        print(f"       {Color.WHITE}Signal     : {sig_color}{sig_display}  {sig_label}{Color.RESET}")
        if radio != 'Unknown':
            print(f"       {Color.WHITE}Radio Type : {Color.CYAN}{radio}{Color.RESET}")
        print()

    # Summary
    print(f"{Color.PURPLE}{'═'*70}{Color.RESET}")
    print(f"{Color.BOLD}{Color.CYAN}  📊 SECURITY SUMMARY{Color.RESET}")
    print(f"{Color.PURPLE}{'═'*70}{Color.RESET}")
    print(f"  {Color.WHITE}Total Networks  : {Color.CYAN}{total}")
    print(f"  {Color.GREEN}Secure Networks : {secure}")
    print(f"  {Color.RED}Open Networks   : {open_nets}  {'⚠️  DANGEROUS!' if open_nets > 0 else '✅'}")
    print(f"  {Color.RED}WEP Networks    : {wep_nets}  {'⚠️  VULNERABLE!' if wep_nets > 0 else '✅'}{Color.RESET}")

    # Warnings
    if open_nets > 0:
        print(f"\n  {Color.RED}⚠️  WARNING: {open_nets} OPEN network(s) detected!")
        print(f"  Never connect to open networks without a VPN!{Color.RESET}")
    if wep_nets > 0:
        print(f"\n  {Color.RED}⚠️  WARNING: {wep_nets} WEP network(s) detected!")
        print(f"  WEP encryption is outdated and easily cracked!{Color.RESET}")
    if open_nets == 0 and wep_nets == 0:
        print(f"\n  {Color.GREEN}✅ All nearby networks use modern encryption!{Color.RESET}")

    print(f"{Color.PURPLE}{'═'*70}{Color.RESET}\n")

